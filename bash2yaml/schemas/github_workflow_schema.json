{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://json.schemastore.org/github-workflow.json",
  "title": "GitHub Actions Workflow",
  "description": "Minimal fallback schema for GitHub Actions workflows. Fetched from SchemaStore when available.",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the workflow."
    },
    "run-name": {
      "type": "string",
      "description": "The name for workflow runs generated from the workflow."
    },
    "on": {
      "description": "The event that triggers the workflow."
    },
    "permissions": {
      "description": "Permissions for the GITHUB_TOKEN."
    },
    "env": {
      "type": "object",
      "description": "A map of environment variables available to all jobs and steps.",
      "additionalProperties": {
        "type": ["string", "number", "boolean"]
      }
    },
    "defaults": {
      "type": "object",
      "description": "Default settings for all jobs in the workflow."
    },
    "concurrency": {
      "description": "Concurrency settings for the workflow."
    },
    "jobs": {
      "type": "object",
      "description": "A map of jobs that the workflow will run.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "needs": {},
          "runs-on": {},
          "permissions": {},
          "environment": {},
          "concurrency": {},
          "outputs": {
            "type": "object"
          },
          "env": {
            "type": "object",
            "additionalProperties": {
              "type": ["string", "number", "boolean"]
            }
          },
          "defaults": {
            "type": "object"
          },
          "if": {},
          "steps": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "if": {},
                "name": {
                  "type": "string"
                },
                "uses": {
                  "type": "string"
                },
                "run": {
                  "type": "string"
                },
                "working-directory": {
                  "type": "string"
                },
                "shell": {
                  "type": "string"
                },
                "with": {
                  "type": "object"
                },
                "env": {
                  "type": "object",
                  "additionalProperties": {
                    "type": ["string", "number", "boolean"]
                  }
                },
                "continue-on-error": {},
                "timeout-minutes": {
                  "type": "number"
                }
              },
              "additionalProperties": false
            }
          },
          "timeout-minutes": {
            "type": "number"
          },
          "strategy": {
            "type": "object"
          },
          "continue-on-error": {},
          "container": {},
          "services": {
            "type": "object"
          },
          "uses": {
            "type": "string"
          },
          "with": {
            "type": "object"
          },
          "secrets": {}
        },
        "additionalProperties": false
      },
      "minProperties": 1
    }
  },
  "required": ["on", "jobs"],
  "additionalProperties": false
}
