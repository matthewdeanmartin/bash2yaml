# Auto-generated Makefile for GitLab CI jobs
# Use 'make <job_name>' to run a job with proper before/after script handling

.PHONY: help

help:
	@echo 'Available jobs:'
	@echo '  $[[ inputs.job-prefix ]]-scan'
	@echo ''
	@echo 'Use: make <job_name> to run a job'

.PHONY: inputs.job-prefix-scan
inputs.job-prefix-scan:
	@echo 'Running $[[ inputs.job-prefix ]]-scan main script...'
	@./inputs.job-prefix-scan.sh

.PHONY: all
all: $[[ inputs.job-prefix ]]-scan
